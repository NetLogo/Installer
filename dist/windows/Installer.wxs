<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Package Name="$(name)" Manufacturer="CCL" Version="$(version)" UpgradeCode="$(upgradeCode)">
    <MediaTemplate EmbedCab="yes" />

    <StandardDirectory Id="ProgramFiles6432Folder">
      <Directory Id="RootDirectory" Name="$(name)" FileSource="$(root)">
        <Component Id="InstallerComponent">
          <File Id="InstallerFile" Source="$(name).exe" ProcessorArchitecture="$(arch)" KeyPath="yes" />
        </Component>
      </Directory>
    </StandardDirectory>

    <ComponentGroup Id="AppDirectory">
      <Files Directory="RootDirectory" Subdirectory="app" Include="$(root)\app\**" />
    </ComponentGroup>

    <ComponentGroup Id="RuntimeDirectory">
      <Files Directory="RootDirectory" Subdirectory="runtime" Include="$(root)\runtime\**" />
    </ComponentGroup>

    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="ShortcutFolder" Name="$(name)">
        <Component Id="ShortcutComponent">
          <Shortcut Id="InstallerShortcut" Name="$(name)" Target="[#InstallerFile]" WorkingDirectory="RootDirectory" />
          <RemoveFolder Id="ShortcutFolder" On="uninstall" />
          <RegistryValue Root="HKCU" Key="Software\NetLogo\$(name)" Name="installed" Type="integer" Value="1" KeyPath="yes" />
        </Component>
      </Directory>
    </StandardDirectory>

    <Feature Id="InstallerFeature" Title="$(name)">
      <ComponentRef Id="InstallerComponent" />
      <ComponentGroupRef Id="AppDirectory" />
      <ComponentGroupRef Id="RuntimeDirectory" />
      <ComponentRef Id="ShortcutComponent" />
    </Feature>
  </Package>
</Wix>
